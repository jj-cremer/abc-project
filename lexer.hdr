@ "string.hdr"

enum TokenKind
{
    BAD_TOKEN,
    EOI,
    DECIMAL_LITERAL,
    PLUS,
    ASTERISK,
    IDENTIFIER,
    STRING_LITERAL,
    CHARACTER_LITERAL,
    LPAREN,
    RPAREN,
    MINUS,
    SLASH,
    EQUAL,
    SEMICOLON,
};

type TokenVal: array[39] of char;

struct Token
{
    kind:	TokenKind;
    pos:	struct Pos {
		    row, col: unsigned;
		};
    val:	String;
};

extern token: Token;

extern fn getToken(): TokenKind;

extern fn tokenKindStr(token: Token): -> char;
