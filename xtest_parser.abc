@ <stdio.hdr>
@ "lexer.hdr"
@ "parser.hdr"
@ "gen.hdr"


fn main()
{
    genInitCode();
    genFuncDefBegin("main");
    getToken();
    local expr: -> Expr = parseExpr();
    if (expr && token.kind == EOI) {
	printf("// expr: ");
	printExprTree(expr);
	printf("\n");
	loadExpr(expr);
	
    } else {
	printf("syntax error\n");
    }
    genReturn(2);
    genFuncDefEnd();
}
